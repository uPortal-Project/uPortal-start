<!--
  WebProxyPortlet instance for E2E testing.

  Targets https://example.com/ (RFC 2606 reserved domain — the IETF
  ships it as an intentionally-stable test target). Used by the
  uPortal-start Playwright suite to exercise the proxy fetch + filter
  + render path. Catalog-only: no fragment-layout subscribes to it,
  so it does not appear on any default tab and does not affect the
  per-role smoke specs.
-->
<portlet-definition xmlns="https://source.jasig.org/schemas/uportal/io/portlet-definition" xmlns:ns2="https://source.jasig.org/schemas/uportal" xmlns:ns3="https://source.jasig.org/schemas/uportal/io/permission-owner" xmlns:ns4="https://source.jasig.org/schemas/uportal/io/stylesheet-descriptor" xmlns:ns5="https://source.jasig.org/schemas/uportal/io/portlet-type" xmlns:ns6="https://source.jasig.org/schemas/uportal/io/user" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="4.0" xsi:schemaLocation="https://source.jasig.org/schemas/uportal/io/portlet-definition https://source.jasig.org/schemas/uportal/io/portlet-definition/portlet-definition-4.0.xsd">
    <title>Example Domain (test proxy)</title>
    <name>Example Domain (test proxy)</name>
    <fname>web-proxy-example</fname>
    <desc>Proxies https://example.com/ — used by Playwright tests.</desc>
    <type>Portlet</type>
    <timeout>10000</timeout>
    <portlet-descriptor>
        <ns2:webAppName>/WebProxyPortlet</ns2:webAppName>
        <ns2:portletName>WebProxyPortlet</ns2:portletName>
    </portlet-descriptor>
    <category>Testing</category>
    <group>Authenticated Users</group>
    <permissions>
        <permission system="UP_PORTLET_SUBSCRIBE" activity="BROWSE">
            <group>Authenticated Users</group>
        </permission>
    </permissions>
    <parameter>
        <name>configurable</name>
        <value>true</value>
    </parameter>
    <parameter>
        <name>disableDynamicTitle</name>
        <value>true</value>
    </parameter>
    <parameter>
        <name>iconUrl</name>
        <value>/ResourceServingWebapp/rs/tango/0.8.90/32x32/apps/internet-web-browser.png</value>
    </parameter>
    <portlet-preference>
        <name>contentService</name>
        <readOnly>false</readOnly>
        <value>httpContentService</value>
    </portlet-preference>
    <portlet-preference>
        <name>location</name>
        <readOnly>false</readOnly>
        <!--
          Plain HTTP intentional. Tomcat's bundled JDK trust store rejects
          example.com's TLS cert with a handshake_failure (older trust
          anchor set vs. modern serving cipher) and example.com responds
          200 OK over HTTP without redirect, so plain HTTP keeps the
          test path working without doctoring the JDK trust store.
        -->
        <value>http://example.com/</value>
    </portlet-preference>
    <portlet-preference>
        <name>filters</name>
        <readOnly>false</readOnly>
        <value>urlRewritingFilter</value>
    </portlet-preference>
</portlet-definition>
